# Copy this file to .env and fill in your values.
# All variables are optional — the defaults target the public testnet deployment.

# ── RPC ──────────────────────────────────────────────────────────────────────

# Soroban RPC endpoint.
# Defaults to the public Stellar testnet RPC when omitted.
# For mainnet use: https://soroban-mainnet.stellar.org
# For a self-hosted node, point this at your own endpoint.
RPC_URL=https://soroban-testnet.stellar.org

# ── Contract ──────────────────────────────────────────────────────────────────

# The splitter contract to index.
# Defaults to the current testnet deployment of Tributary.
# Replace with your own contract ID when running against a custom deployment.
CONTRACT_ID=CCZXVZUQIZT673QF6ZGLI5AJLEPWUFWVYOPIOJNLNIOO5NI27V4JGJUU

# ── Output ────────────────────────────────────────────────────────────────────

# Path to the newline-delimited JSON file that events are appended to.
OUT=events.ndjson

# Path to the cursor state file.
# The last processed RPC cursor is persisted here so restarts pick up where
# they left off without re-indexing from scratch.
STATE=state.json

# ── Polling ───────────────────────────────────────────────────────────────────

# How often to poll the RPC for new events, in milliseconds.
POLL_MS=10000

# Initial delay before retrying after an RPC rate-limit (429) response, in ms.
# Doubles on each consecutive rate-limit up to BACKOFF_MAX_MS.
BACKOFF_INITIAL_MS=1000

# Maximum exponential-backoff delay, in milliseconds.
BACKOFF_MAX_MS=60000

# ── Logging ───────────────────────────────────────────────────────────────────

# Log verbosity level. Structured JSON lines are written to stdout (info/debug)
# or stderr (warn/error).
# Allowed values: debug | info | warn | error
LOG_LEVEL=info
